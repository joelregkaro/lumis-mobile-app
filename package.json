{
  "name": "app",
  "version": "1.0.0",
  "main": "index.ts",
  "expo-router": {
    "root": "./src/app"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "ipa:eas": "eas build -p ios --profile production --non-interactive",
    "ipa:prebuild": "SENTRY_DISABLE_AUTO_UPLOAD=true npx expo prebuild -p ios",
    "ipa:local": "export SENTRY_DISABLE_AUTO_UPLOAD=true; npx expo prebuild -p ios && (cd ios && xcodebuild -workspace Lumis.xcworkspace -scheme Lumis -configuration Release -archivePath ../build/Lumis.xcarchive archive && xcodebuild -exportArchive -archivePath ../build/Lumis.xcarchive -exportPath ../build/ipa -exportOptionsPlist ../ExportOptions.plist)",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/metro-runtime": "^55.0.6",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sentry/react-native": "^7.11.0",
    "@siteed/expo-audio-studio": "^2.18.6",
    "@supabase/supabase-js": "^2.98.0",
    "babel-preset-expo": "^55.0.10",
    "base64-js": "^1.5.1",
    "expo": "~55.0.5",
    "expo-apple-authentication": "^55.0.8",
    "expo-audio": "^55.0.8",
    "expo-auth-session": "^55.0.7",
    "expo-constants": "~55.0.7",
    "expo-crypto": "^55.0.9",
    "expo-dev-client": "^55.0.11",
    "expo-device": "^55.0.9",
    "expo-file-system": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.8",
    "expo-linear-gradient": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-notifications": "^55.0.11",
    "expo-router": "~55.0.4",
    "expo-sharing": "~55.0.11",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "nativewind": "^4.2.2",
    "react-native-css-interop": "^0.2.2",
    "posthog-react-native": "^4.37.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-audio-api": "^0.11.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-view-shot": "^4.0.3",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.7.2",
    "tailwindcss": "^3.4.17",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "eas-cli": "^18.1.0",
    "patch-package": "^8.0.0",
    "typescript": "~5.9.3"
  },
  "private": true
}
